#include <iostream>

using namespace std;

int main(void)
{
	char text[100];
	int c = 1;
	while (true)
	{
		cout << "영문텍스트를 입력하세요(빈칸 포함 가능)>>";
		cin.getline(text, sizeof(text), '\n');
		for (int i = 0; text[i] != '\0'; i++)
		{
			if (text[i] == ' ') c ++;
		}
		cout << "단어의 개수는" << c << "개이다.\n";
		c = 1;
		if (strcmp(text, "exit") == 0) break;
	}

	return 0;
}
