#include <iostream>
using namespace std;
int main(void)
{
	char text[100];
	int c = 0, i;
	while (true)
	{
		cout << "영문텍스트를 입력하세요(빈칸 포함 가능)>>";
		cin.getline(text, sizeof(text), '\n');
		for (i = 0; text[i] != '\0'; i++)
		{
			if (text[i] == ' ') c++;
		}
		if (strcmp(text, "exit") == 0) break;
		if (text[i] == '\n') cout<<"단어의 개수는  0개이다.\n";
		else cout << "단어의 개수는" << c << "개이다.\n";
		c = 1;
	}

	return 0;
}
